{
    "name": "utsaregplus",
    "private": true,
    "version": "0.0.0",
    "description": "UTSA Registration Plus — the canonical UTSA student registration tool.",
    "type": "module",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "npm run build --workspace=@utsaregplus/extension",
        "dev": "npm run dev --workspace=@utsaregplus/extension",
        "test": "npm run test --workspaces --if-present",
        "typecheck": "npm run typecheck --workspaces --if-present",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "devDependencies": {
        "@eslint/js": "^9.18.0",
        "@types/node": "^25.3.3",
        "eslint": "^9.18.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.4",
        "eslint-plugin-react-hooks": "^5.1.0",
        "globals": "^15.14.0",
        "prettier": "^3.4.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.21.0",
        "vitest": "^2.1.8"
    },
    "engines": {
        "node": ">=20"
    }
}
